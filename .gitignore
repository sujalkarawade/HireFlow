# ============================================================
#  RecruitPro — .gitignore
#  Covers: Python/FastAPI backend + Vite/React frontend
# ============================================================

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
wheels/
*.whl
*.spec
MANIFEST
.eggs/

# Unit test / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ── FastAPI / Uvicorn ────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# Uploaded files (resume PDFs)
backend/uploads/

# ── Node / Vite / React ──────────────────────────────────────
node_modules/
frontend/node_modules/

# Build output
frontend/dist/
frontend/build/
frontend/.vite/

# Vite cache
frontend/.vite-cache/

# ── Environment & Secrets ────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
*.env

# ── IDE & Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.DS_Store
Thumbs.db

# ── OS ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
